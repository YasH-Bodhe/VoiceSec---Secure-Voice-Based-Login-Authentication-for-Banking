# Voice Banking Authentication System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# JWT Configuration
# ============================================================================
# Secret key for JWT token generation (change this to a secure random string)
SECRET_KEY=your-super-secret-key-change-this-in-production

# ============================================================================
# Email Configuration (Gmail SMTP for OTP)
# ============================================================================
# Gmail SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Your Gmail email address
SENDER_EMAIL=yashsih30@gmail.com

# IMPORTANT: Use Gmail App Password, NOT your Gmail password!
# Steps to get App Password:
# 1. Enable 2-Factor Authentication on your Google Account
#    - Go to https://myaccount.google.com/security
#    - Enable 2-Step Verification
# 2. Generate App Password
#    - Go to https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer" (or your OS)
#    - Google will generate a 16-character password
# 3. Copy the generated password below (without spaces)
SENDER_PASSWORD=your-16-character-app-password

# ============================================================================
# Database Configuration
# ============================================================================
# Path to SQLite database file
DATABASE_PATH=database/database.db

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8000
DEBUG=False

# ============================================================================
# Audio Processing Configuration
# ============================================================================
# Audio sample rate (ECAPA-TDNN requires 16kHz)
SAMPLE_RATE=16000

# ============================================================================
# Authentication Thresholds (Advanced)
# ============================================================================
# Voice similarity threshold for direct authentication (0.0-1.0)
SIMILARITY_THRESHOLD_HIGH=0.85

# Voice similarity threshold for OTP fallback (0.0-1.0)
SIMILARITY_THRESHOLD_LOW=0.70

# Anti-spoofing detection threshold (0.0-1.0)
SPOOF_THRESHOLD=0.5

